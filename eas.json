{
    "cli": {
        "version": ">= 15.0.4",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "ios": { "simulator": false },
            "android": { "buildType": "apk" }
        },
        "production": {
            "ios": { "distribution": "store" },
            "android": { "buildType": "apk" }
        }
    },
    "submit": {
        "production": {
            "ios": { "appleId": "ios@justpoint.com", "ascAppId": "com.justpoint.hiddendanger" },
            "android": { "serviceAccountKeyPath": "./app/google-services.json" }
        }
    }
}
